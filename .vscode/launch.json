{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug COBOL (C/C++ extension - cppdbg)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "lldb",
      "miDebuggerPath": "/usr/bin/lldb",
      "preLaunchTask": "cobol: build current file"
    },
    {
      "name": "Debug COBOL (CodeLLDB extension)",
      "type": "lldb",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "cobol: build current file"
    }
  ]
}
